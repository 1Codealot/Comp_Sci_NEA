i = int(input("Enter a number: "))

if i == 5 then
    print("i is 5\n")
endif

if i MOD 2 == 0 then
    print("i is even\n")
else
    print("i is odd\n")
endif

if i MOD 3 == 0 then
    print("i is divisible by 3\n")
elseif i MOD 3 == 1 then
    print("i has remainder 1 when divided by 3\n")
else 
    print("i has remainder 2 when divided by 3\n")
endif

