if 1+1==2 then
    print("true")
endif

i = 0

while i != 5
    i = i + 1
    if i MOD 2 == 0
        print(str(i) + "is even\n")
    endif
endwhile

for n = 0 to 10
    k = n
    do
        print("*")
        k = k-1
    until k == 0
    print("\n")
next n

