function string_char_at(str_in, index)
    return str_in.substring(index,1)
endfunction

input_text = open("input.txt")

joltage = 0
num_size = 2

while NOT input_text.endOfFile()
    array largest_nums[2]
    line = input_text.readLine()


    next_start_index = -1
    for x = 0 to num_size - 1
    largest_nums[x] = 0
    i = next_start_index + 1
        while i < line.length - ((num_size - 1) - x) - 1
            if int(string_char_at(line, i)) > largest_nums[x] then
                next_start_index = i
                largest_nums[x] = int(string_char_at(line, i))
            endif
            i = i + 1
        endwhile
    next x

    tmp = 0

    for j = 0 to num_size-1
        tmp = tmp * 10
        tmp = tmp + largest_nums[j]
    next j
    print(str(tmp) + "\n")
    joltage = joltage + tmp

endwhile


print(str(joltage) + "\n")