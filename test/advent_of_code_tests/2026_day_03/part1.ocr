function string_char_at(str_in, index)
    return str_in.substring(index,1)
endfunction

input_text = open("input.txt")

joltage = 0

while NOT input_text.endOfFile()
    array largest_nums = [0,0]
    line = input_text.readLine()

    next_start_idx = 0
    for i = 0 to line.length -3 /* -1 to counteract off by 1 error, -1 for no \n inclusion, 
    -1 so the last number can be used for the second number*/
        if int(string_char_at(line, i)) > largest_nums[0] then
            largest_nums[0] = int(string_char_at(line, i))
            next_start_index = i
        endif
    next i

    for i = next_start_index+1 to line.length - 2
        if int(string_char_at(line, i)) > largest_nums[1] then
            largest_nums[1] = int(string_char_at(line, i))
            next_start_index = i
        endif
    next i 
    joltage = joltage + ((largest_nums[0]*10) + largest_nums[1])
endwhile


print(str(joltage) + "\n")