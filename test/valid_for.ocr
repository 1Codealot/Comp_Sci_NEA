for i = 0 to 5
    print("Hello world\n")
next i

print("Even numbers to 100\n")

for i = 2 to 100 step 2
    print(str(i) + " ")
next i

print("\n")

for m =0 to 5
    for n= 0 to m
        print("*")
    next n
    print("\n")
next m

w = 7
x = 10
y = 3
for z = w + 2 to x + 5 step y-2
    print(str(z) + "\n")
next z