function gradient(x1, x2, y1, y2): // The : is not technically valid; but it gets past the syntax checker, though it shouldn't...
    return (y2-y1) / (x2-x1)
endfunction

x1 = real(input("Enter x1: "))
y1 = real(input("Enter y1: "))
x2 = real(input("Enter x2: "))
y2 = real(input("Enter y2: "))

result = gradient(x1,x2,y1,y2)
input(result)